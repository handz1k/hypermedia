# Backend simulation parameters
STOCK_COUNT=50
UPDATE_INTERVAL_MS=250
VOLATILITY=0.008   # per-tick log-normal std dev; 0.008 ≈ 0.8% typical move per tick
DRIFT=0.0001
INITIAL_PRICE_MIN=10
INITIAL_PRICE_MAX=500

# Server ports (inside container; host ports set in docker-compose.yml)
APP_PORT=3000
METRICS_PORT=9091

# CDP measurement parameters
CDP_HDA_URL=http://localhost:8080
CDP_SPA_URL=http://localhost:8081
CDP_DURATION_SECONDS=60

# Load test parameters (used by run-measurements.sh)
K6_VUS_STEADY=50
K6_VUS_SPIKE=200
